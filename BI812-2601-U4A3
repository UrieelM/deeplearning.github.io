<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>A3 – Cuadro Comparativo Deep Learning</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Serif+Display&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0c10;
    --surface: #111318;
    --surface2: #181b22;
    --border: #222633;
    --accent-cnn: #00c2ff;
    --accent-rnn: #a78bfa;
    --accent-gan: #fb923c;
    --accent-ae: #34d399;
    --accent-trans: #f472b6;
    --text: #e2e8f0;
    --text-muted: #64748b;
    --text-dim: #94a3b8;
    --gold: #f59e0b;
    --header-h: 72px;
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 13.5px;
    line-height: 1.55;
  }

  /* ─── PORTADA / HEADER ─────────────────────────────────── */
  .hero {
    position: relative;
    width: 100%;
    padding: 64px 80px 56px;
    background: linear-gradient(135deg, #0a0c10 0%, #0d1120 60%, #101624 100%);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 600px 300px at 80% 50%, rgba(0,194,255,.07) 0%, transparent 70%),
      radial-gradient(ellipse 400px 400px at 20% 80%, rgba(167,139,250,.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-label {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent-cnn);
    margin-bottom: 16px;
    opacity: .8;
  }
  .hero h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 400;
    line-height: 1.1;
    color: #fff;
    max-width: 760px;
    margin-bottom: 18px;
  }
  .hero h1 span { color: var(--accent-cnn); }
  .hero-sub {
    font-size: 14px;
    color: var(--text-dim);
    max-width: 560px;
    margin-bottom: 36px;
  }
  .pill-row { display:flex; gap:10px; flex-wrap:wrap; }
  .pill {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    padding: 5px 14px;
    border-radius: 100px;
    border: 1px solid;
    letter-spacing: .5px;
  }
  .pill.cnn { color:var(--accent-cnn); border-color:rgba(0,194,255,.3); background:rgba(0,194,255,.06); }
  .pill.rnn { color:var(--accent-rnn); border-color:rgba(167,139,250,.3); background:rgba(167,139,250,.06); }
  .pill.gan { color:var(--accent-gan); border-color:rgba(251,146,60,.3); background:rgba(251,146,60,.06); }
  .pill.ae  { color:var(--accent-ae);  border-color:rgba(52,211,153,.3);  background:rgba(52,211,153,.06); }
  .pill.tr  { color:var(--accent-trans);border-color:rgba(244,114,182,.3);background:rgba(244,114,182,.06); }
  .meta-row { display:flex; gap:32px; flex-wrap:wrap; margin-top:32px; }
  .meta-item label { display:block; font-size:10px; letter-spacing:2px; color:var(--text-muted); text-transform:uppercase; margin-bottom:3px; }
  .meta-item span  { font-size:13px; color:var(--text-dim); }

  /* ─── LAYOUT SHELL ─────────────────────────────────────── */
  .shell { max-width: 1400px; margin: 0 auto; padding: 0 40px 80px; }

  /* ─── SECTION HEADERS ───────────────────────────────────── */
  .sec-head {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 48px 0 24px;
  }
  .sec-head .num {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 2px;
  }
  .sec-head h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
    font-weight: 400;
    color: #fff;
  }
  .sec-line { flex:1; height:1px; background:var(--border); }

  /* ─── ALGORITHM CARDS ───────────────────────────────────── */
  .algo-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:20px; }
  .algo-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    position: relative;
    overflow: hidden;
    transition: transform .2s, border-color .2s;
  }
  .algo-card:hover { transform: translateY(-3px); }
  .algo-card::before {
    content:'';
    position:absolute;
    top:0; left:0; right:0;
    height:3px;
  }
  .algo-card.cnn::before { background: var(--accent-cnn); }
  .algo-card.rnn::before { background: var(--accent-rnn); }
  .algo-card.gan::before { background: var(--accent-gan); }
  .algo-card.ae::before  { background: var(--accent-ae); }
  .algo-card.tr::before  { background: var(--accent-trans); }

  .algo-card:hover.cnn { border-color: rgba(0,194,255,.4); }
  .algo-card:hover.rnn { border-color: rgba(167,139,250,.4); }
  .algo-card:hover.gan { border-color: rgba(251,146,60,.4); }
  .algo-card:hover.ae  { border-color: rgba(52,211,153,.4); }
  .algo-card:hover.tr  { border-color: rgba(244,114,182,.4); }

  .algo-icon { font-size: 32px; margin-bottom:14px; }
  .algo-name {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 2px;
  }
  .cnn .algo-name { color:var(--accent-cnn); }
  .rnn .algo-name { color:var(--accent-rnn); }
  .gan .algo-name { color:var(--accent-gan); }
  .ae  .algo-name { color:var(--accent-ae); }
  .tr  .algo-name { color:var(--accent-trans); }

  .algo-full { font-size:11px; color:var(--text-muted); margin-bottom:12px; }
  .algo-desc { font-size:13px; color:var(--text-dim); line-height:1.6; margin-bottom:16px; }

  .info-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
  .info-item label { display:block; font-size:9.5px; letter-spacing:1.5px; text-transform:uppercase; color:var(--text-muted); margin-bottom:3px; }
  .info-item span  { font-size:12px; color:var(--text); }

  /* ─── ARQUITECTURA DIAGRAMS ─────────────────────────────── */
  .arch-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(340px,1fr)); gap:20px; }
  .arch-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius:12px;
    padding: 24px;
  }
  .arch-card h3 {
    font-family:'Space Mono',monospace;
    font-size:11px;
    letter-spacing:2px;
    text-transform:uppercase;
    margin-bottom:20px;
  }
  .cnn .arch-card h3 { color:var(--accent-cnn); }

  /* SVG diagram styles */
  .arch-svg { width:100%; }

  /* ─── TABLA COMPARATIVA ─────────────────────────────────── */
  .table-wrap { overflow-x:auto; border-radius:12px; border:1px solid var(--border); }
  table { width:100%; border-collapse:collapse; min-width:900px; }
  thead th {
    background: var(--surface2);
    padding: 16px 14px;
    text-align:left;
    font-family:'Space Mono',monospace;
    font-size:10px;
    letter-spacing:2px;
    text-transform:uppercase;
    border-bottom: 1px solid var(--border);
    white-space:nowrap;
  }
  thead th:first-child { color:var(--text-muted); min-width:200px; }
  thead th.cnn { color:var(--accent-cnn); }
  thead th.rnn { color:var(--accent-rnn); }
  thead th.gan { color:var(--accent-gan); }
  thead th.ae  { color:var(--accent-ae); }
  thead th.tr  { color:var(--accent-trans); }

  tbody tr { border-bottom:1px solid var(--border); transition: background .15s; }
  tbody tr:hover { background: rgba(255,255,255,.025); }
  tbody tr:last-child { border-bottom:none; }
  tbody td { padding:13px 14px; vertical-align:top; }
  tbody td:first-child {
    font-family:'Space Mono',monospace;
    font-size:11px;
    color:var(--text-dim);
    letter-spacing:.5px;
    font-weight:700;
    background: var(--surface);
    border-right:1px solid var(--border);
    width:200px;
  }
  tbody td:not(:first-child) { font-size:12.5px; color:var(--text-dim); line-height:1.5; }

  /* rating badges */
  .rate {
    display:inline-flex;
    align-items:center;
    gap:4px;
    font-family:'Space Mono',monospace;
    font-size:11px;
    padding:2px 8px;
    border-radius:4px;
    margin-bottom:4px;
  }
  .rate.hi  { background:rgba(52,211,153,.12); color:var(--accent-ae); }
  .rate.mid { background:rgba(251,146,60,.12);  color:var(--accent-gan); }
  .rate.lo  { background:rgba(100,116,139,.12); color:var(--text-muted); }

  /* ─── CUANTITATIVE EVAL ─────────────────────────────────── */
  .eval-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:16px; }
  .eval-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius:12px;
    padding:24px;
    text-align:center;
  }
  .eval-card .algo-label {
    font-family:'Space Mono',monospace;
    font-size:11px;
    font-weight:700;
    letter-spacing:1px;
    margin-bottom:16px;
  }
  .radial-wrap { position:relative; width:120px; height:120px; margin:0 auto 16px; }
  .radial-wrap svg { transform:rotate(-90deg); }
  .radial-center {
    position:absolute; inset:0;
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
  }
  .radial-score { font-family:'DM Serif Display',serif; font-size:28px; color:#fff; }
  .radial-max   { font-size:11px; color:var(--text-muted); }
  .bar-row { margin-bottom:8px; }
  .bar-label { display:flex; justify-content:space-between; font-size:11px; color:var(--text-muted); margin-bottom:3px; }
  .bar-track { height:4px; background:var(--border); border-radius:2px; overflow:hidden; }
  .bar-fill  { height:100%; border-radius:2px; }

  /* ─── BIBLIOGRAPHY ──────────────────────────────────────── */
  .bib-list { list-style:none; counter-reset:ref; }
  .bib-list li {
    counter-increment:ref;
    padding:12px 0 12px 52px;
    border-bottom:1px solid var(--border);
    position:relative;
    font-size:12.5px;
    color:var(--text-dim);
    line-height:1.6;
  }
  .bib-list li::before {
    content: counter(ref);
    position:absolute;
    left:0;
    font-family:'Space Mono',monospace;
    font-size:10px;
    color:var(--text-muted);
    background:var(--surface);
    border:1px solid var(--border);
    border-radius:4px;
    width:28px; height:28px;
    display:flex; align-items:center; justify-content:center;
    top:14px;
  }
  .bib-list li:last-child { border:none; }
  .bib-list em { font-style:italic; }

  /* ─── FOOTER ─────────────────────────────────────────────── */
  footer {
    border-top:1px solid var(--border);
    padding:24px 40px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    font-family:'Space Mono',monospace;
    font-size:10px;
    color:var(--text-muted);
    letter-spacing:1px;
    max-width:1400px;
    margin:0 auto;
    flex-wrap:wrap;
    gap:8px;
  }

  /* ─── CHIP ─────────────────────────────────────────────── */
  .chip {
    display:inline-block;
    font-size:11px;
    padding:2px 8px;
    border-radius:4px;
    margin:2px;
  }
  .chip.cnn { background:rgba(0,194,255,.1);  color:var(--accent-cnn); }
  .chip.rnn { background:rgba(167,139,250,.1);color:var(--accent-rnn); }
  .chip.gan { background:rgba(251,146,60,.1); color:var(--accent-gan); }
  .chip.ae  { background:rgba(52,211,153,.1); color:var(--accent-ae); }
  .chip.tr  { background:rgba(244,114,182,.1);color:var(--accent-trans); }

  /* ─── PRINT ─────────────────────────────────────────────── */
  @media print {
    body { font-size:12px; }
    .hero { padding:40px; }
    .algo-card, .arch-card, .eval-card { break-inside:avoid; }
  }
</style>
</head>
<body>

<!-- ══════════════════════════════════════════════════════════
     PORTADA
═══════════════════════════════════════════════════════════ -->
<header class="hero">
  <p class="hero-label">A3 · Cuadro Comparativo · Universidad La Salle Bajío</p>
  <h1>Algoritmos de<br><span>Deep Learning</span></h1>
  <p class="hero-sub">Análisis comparativo de los principales paradigmas: arquitectura, fundamentos, aplicaciones y evaluación cuantitativa.</p>
  <div class="pill-row">
    <span class="pill cnn">CNN</span>
    <span class="pill rnn">RNN / LSTM</span>
    <span class="pill gan">GAN</span>
    <span class="pill ae">Autoencoders</span>
    <span class="pill tr">Transformers</span>
  </div>
  <div class="meta-row">
    <div class="meta-item"><label>Alumno</label><span>Uriel Mendoza Rodríguez</span></div>
    <div class="meta-item"><label>Profesor</label><span>Rodolfo Rocha Urrutia</span></div>
    <div class="meta-item"><label>Materia</label><span>Desarrollo de Inteligencia de Negocios</span></div>
    <div class="meta-item"><label>Tipo</label><span>Cuadro Comparativo</span></div>
    <div class="meta-item"><label>Norma bibliográfica</label><span>APA 7ª edición</span></div>
    <div class="meta-item"><label>Año</label><span>2025</span></div>
  </div>
</header>

<div class="shell">

<!-- ══════════════════════════════════════════════════════════
     1. FICHAS POR ALGORITMO
═══════════════════════════════════════════════════════════ -->
<div class="sec-head">
  <span class="num">01</span>
  <h2>Fundamentos por Algoritmo</h2>
  <div class="sec-line"></div>
</div>

<div class="algo-grid">

  <!-- CNN -->
  <div class="algo-card cnn">
    <div class="algo-icon">🧠</div>
    <div class="algo-name">CNN</div>
    <div class="algo-full">Convolutional Neural Network</div>
    <div class="algo-desc">
      Inspiradas en la corteza visual del cerebro, aplican filtros convolucionales para extraer características espaciales jerárquicas. Son el estándar de facto en visión por computadora.
    </div>
    <div class="info-grid">
      <div class="info-item"><label>Creadores</label><span>LeCun, Bengio, Hinton (1989–1998)</span></div>
      <div class="info-item"><label>Hito</label><span>LeNet-5 (1998), AlexNet (2012)</span></div>
      <div class="info-item"><label>Entrada típica</label><span>Imágenes, video, datos 2D</span></div>
      <div class="info-item"><label>Operación clave</label><span>Convolución + Pooling</span></div>
      <div class="info-item"><label>Frameworks</label><span>PyTorch, TensorFlow/Keras</span></div>
      <div class="info-item"><label>Costo cómputo</label><span>Medio–Alto (GPU)</span></div>
    </div>
  </div>

  <!-- RNN/LSTM -->
  <div class="algo-card rnn">
    <div class="algo-icon">🔄</div>
    <div class="algo-name">RNN / LSTM</div>
    <div class="algo-full">Recurrent Neural Network / Long Short-Term Memory</div>
    <div class="algo-desc">
      Procesan secuencias manteniendo un estado oculto que actúa como memoria. LSTM resuelve el problema del gradiente que desaparece mediante compuertas de control de flujo de información.
    </div>
    <div class="info-grid">
      <div class="info-item"><label>Creadores</label><span>Elman (1990); Hochreiter &amp; Schmidhuber (1997)</span></div>
      <div class="info-item"><label>Hito</label><span>LSTM (1997), GRU (2014)</span></div>
      <div class="info-item"><label>Entrada típica</label><span>Series temporales, texto, audio</span></div>
      <div class="info-item"><label>Operación clave</label><span>Estado recurrente + compuertas</span></div>
      <div class="info-item"><label>Frameworks</label><span>PyTorch, Keras, TF</span></div>
      <div class="info-item"><label>Costo cómputo</label><span>Medio (secuencial)</span></div>
    </div>
  </div>

  <!-- GAN -->
  <div class="algo-card gan">
    <div class="algo-icon">🎭</div>
    <div class="algo-name">GAN</div>
    <div class="algo-full">Generative Adversarial Network</div>
    <div class="algo-desc">
      Dos redes compiten: el generador crea muestras sintéticas y el discriminador las evalúa. El equilibrio de Nash emerge cuando el discriminador ya no puede distinguir datos reales de sintéticos.
    </div>
    <div class="info-grid">
      <div class="info-item"><label>Creadores</label><span>Ian Goodfellow et al. (2014)</span></div>
      <div class="info-item"><label>Hito</label><span>StyleGAN (2019), DALL-E (2021)</span></div>
      <div class="info-item"><label>Entrada típica</label><span>Ruido latente (vector z)</span></div>
      <div class="info-item"><label>Operación clave</label><span>Juego minimax adversarial</span></div>
      <div class="info-item"><label>Frameworks</label><span>PyTorch, JAX</span></div>
      <div class="info-item"><label>Costo cómputo</label><span>Muy alto (inestable)</span></div>
    </div>
  </div>

  <!-- Autoencoders -->
  <div class="algo-card ae">
    <div class="algo-icon">🗜️</div>
    <div class="algo-name">Autoencoders</div>
    <div class="algo-full">Autoencoder / Variational Autoencoder (VAE)</div>
    <div class="algo-desc">
      Aprenden una representación comprimida (espacio latente) de los datos al reconstruirlos a través de un cuello de botella. Los VAE agregan restricciones probabilísticas al espacio latente para generación controlada.
    </div>
    <div class="info-grid">
      <div class="info-item"><label>Creadores</label><span>Rumelhart et al. (1986); Kingma &amp; Welling (2013)</span></div>
      <div class="info-item"><label>Hito</label><span>VAE (2013), β-VAE (2017)</span></div>
      <div class="info-item"><label>Entrada típica</label><span>Imágenes, señales, texto</span></div>
      <div class="info-item"><label>Operación clave</label><span>Encoder → z → Decoder</span></div>
      <div class="info-item"><label>Frameworks</label><span>PyTorch, Keras</span></div>
      <div class="info-item"><label>Costo cómputo</label><span>Bajo–Medio</span></div>
    </div>
  </div>

  <!-- Transformers -->
  <div class="algo-card tr">
    <div class="algo-icon">⚡</div>
    <div class="algo-name">Transformers</div>
    <div class="algo-full">Transformer / Self-Attention Network</div>
    <div class="algo-desc">
      Eliminan la recurrencia y el convolucionado mediante mecanismos de atención multi-cabeza que relacionan cualquier par de posiciones en una secuencia en tiempo constante, logrando paralelismo total.
    </div>
    <div class="info-grid">
      <div class="info-item"><label>Creadores</label><span>Vaswani et al. — Google Brain (2017)</span></div>
      <div class="info-item"><label>Hito</label><span>BERT (2018), GPT-3 (2020), ViT (2020)</span></div>
      <div class="info-item"><label>Entrada típica</label><span>Tokens (texto, imágenes, audio)</span></div>
      <div class="info-item"><label>Operación clave</label><span>Self-Attention + Feed-Forward</span></div>
      <div class="info-item"><label>Frameworks</label><span>HuggingFace, JAX, PyTorch</span></div>
      <div class="info-item"><label>Costo cómputo</label><span>Muy alto (escala)</span></div>
    </div>
  </div>

</div><!-- /algo-grid -->


<!-- ══════════════════════════════════════════════════════════
     2. DIAGRAMAS DE ARQUITECTURA
═══════════════════════════════════════════════════════════ -->
<div class="sec-head">
  <span class="num">02</span>
  <h2>Arquitecturas</h2>
  <div class="sec-line"></div>
</div>

<div class="arch-grid">

  <!-- CNN Diagram -->
  <div class="arch-card">
    <h3 style="color:var(--accent-cnn)">CNN — Flujo de datos</h3>
    <svg class="arch-svg" viewBox="0 0 380 130" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <marker id="arr" markerWidth="6" markerHeight="6" refX="3" refY="3" orient="auto">
          <path d="M0,0 L6,3 L0,6 Z" fill="#4a5568"/>
        </marker>
      </defs>
      <!-- Input -->
      <rect x="4" y="30" width="48" height="70" rx="4" fill="#111318" stroke="#222633"/>
      <rect x="10" y="36" width="36" height="58" rx="2" fill="rgba(0,194,255,.15)" stroke="rgba(0,194,255,.4)"/>
      <text x="28" y="76" text-anchor="middle" font-size="8" fill="#64748b">Input</text>
      <!-- Conv1 -->
      <line x1="52" y1="65" x2="72" y2="65" stroke="#4a5568" stroke-width="1.2" marker-end="url(#arr)"/>
      <rect x="72" y="25" width="44" height="80" rx="4" fill="#111318" stroke="#222633"/>
      <rect x="76" y="29" width="36" height="72" rx="2" fill="rgba(0,194,255,.12)" stroke="rgba(0,194,255,.35)"/>
      <text x="94" y="68" text-anchor="middle" font-size="8" fill="var(--accent-cnn)">Conv</text>
      <text x="94" y="78" text-anchor="middle" font-size="7" fill="#64748b">+ReLU</text>
      <!-- Pool1 -->
      <line x1="116" y1="65" x2="136" y2="65" stroke="#4a5568" stroke-width="1.2" marker-end="url(#arr)"/>
